# Banco de dados PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/formmaster

# Segredo JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-secret-key-here

# API Key do Gemini Flash — obtenha em https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# Desenvolvimento local — desliga o flag secure no cookie JWT (não usar em produção)
DEBUG=false
